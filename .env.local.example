# Supabase - nuevo proyecto EPSA-Cotizador (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend - envío de emails (resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email desde el que se envían las cotizaciones
RESEND_FROM_EMAIL=cotizador@epsa.com.ar

# Service Role Key - solo para crear usuarios desde admin (Settings → API → service_role)
# NUNCA expongas esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
